# 设备树路径变量，指向当前设备配置目录
DEVICE_PATH := device/xiaomi/myron

# ─────────────────────────────────────────────────────────
# 手电筒配置
# ─────────────────────────────────────────────────────────
# 不使用绿色 LED（设为 0，仅使用黄色闪光灯）
OF_USE_GREEN_LED := 0
# 手电筒控制路径：黄色闪光灯 LED 节点
OF_FL_PATH1 := /sys/class/leds/yellow:flash-0

# ─────────────────────────────────────────────────────────
# 分区工具配置
# ─────────────────────────────────────────────────────────
# 动态分区（super）总大小：14495514624 字节 ≈ 13.5GB
OF_DYNAMIC_FULL_SIZE := 14495514624
# 在格式化时显示文件系统调试信息
OF_DISPLAY_FORMAT_FILESYSTEMS_DEBUG_INFO := 1
# 格式化 Data 分区时强制使用 F2FS 文件系统
OF_FORCE_DATA_FORMAT_F2FS := 1
# 格式化 Data 后自动擦除 metadata 分区（防止加密残留）
OF_WIPE_METADATA_AFTER_DATAFORMAT := 1
# 启用备份 bug 的 workaround 修复
OF_WORKAROUND_BACKUP_BUG := 1

# ─────────────────────────────────────────────────────────
# 内核配置
# ─────────────────────────────────────────────────────────
# 强制使用预编译内核（不从源码编译内核）
OF_FORCE_PREBUILT_KERNEL := 1

# ─────────────────────────────────────────────────────────
# 显示配置
# 分辨率: 1200x2340 (已验证), 状态栏高度: 141 像素
# ─────────────────────────────────────────────────────────
# 屏幕可用高度：2340 像素（除去状态栏和导航栏后的实际内容区域）
OF_SCREEN_H := 2340
# 状态栏高度：141 像素（用于遮盖前置摄像头挖孔区域）
OF_STATUS_H := 141
# 状态栏左侧缩进：48 像素（图标避开屏幕左侧圆角）
OF_STATUS_INDENT_LEFT := 48
# 状态栏右侧缩进：48 像素（图标避开屏幕右侧圆角）
OF_STATUS_INDENT_RIGHT := 48
# 隐藏刘海/挖孔：在状态栏区域绘制纯黑背景，完美遮盖前置摄像头挖孔
OF_HIDE_NOTCH := 1
# 状态栏时钟居中（挖孔屏/药丸屏适配）
OF_CLOCK_POS := 1
# 不允许用户禁用导航栏（设备使用全面屏手势，无实体导航栏）
OF_ALLOW_DISABLE_NAVBAR := 0
# 主菜单选项列表每页显示 6 项
OF_OPTIONS_LIST_NUM := 6

# ─────────────────────────────────────────────────────────
# 语言 / 时区
# ─────────────────────────────────────────────────────────
# 默认时区：亚洲/上海（东八区）
OF_DEFAULT_TIMEZONE := Asia/Shanghai
# 默认语言：简体中文
OF_LANGUAGE := zh_CN
